{
  "permissions": {
    "defaultMode": "bypassPermissions",
    "deny": [
      "Bash(rm:*)",
      "Bash(rmdir:*)",
      "Bash(unlink:*)",
      "Bash(trash:*)",
      "Bash(find * -delete*)",
      "Bash(find * -exec rm*)",
      "Bash(git push --force:*)",
      "Bash(git push -f:*)",
      "Bash(git push --force-with-lease:*)",
      "Bash(git reset --hard:*)",
      "Bash(git reset --keep:*)",
      "Bash(git rebase:*)",
      "Bash(git commit --amend:*)",
      "Bash(git filter-branch:*)",
      "Bash(git filter-repo:*)",
      "Bash(git update-ref -d:*)",
      "Bash(git reflog expire:*)",
      "Bash(git gc:*)",
      "Bash(git branch -D:*)",
      "Bash(git branch -d:*)",
      "Bash(git tag -d:*)",
      "Bash(git checkout --:*)",
      "Bash(git restore --:*)",
      "Bash(git clean -f:*)",
      "Bash(git clean -fd:*)",
      "Bash(git clean -fx:*)",
      "Bash(git stash drop:*)",
      "Bash(git stash clear:*)"
    ]
  },
  "enableAllProjectMcpServers": true
}